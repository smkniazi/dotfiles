#!/bin/bash
create_path_alias(){
	if [ -d "$2" ]; then
		eval "alias $1=\"cd $2\""
	fi
}

# Create a function $1 that cd's into a path under the Hops tree, resolved at
# call time from $HOPS_BASE_DIR (falling back to ~/code/hops). Using a function
# instead of an alias means a per-session "export HOPS_BASE_DIR=..." override is
# honored every time the shortcut is invoked, not frozen when this file is sourced.
create_hops_nav(){
	eval "$1(){ cd \"\${HOPS_BASE_DIR:-\$HOME/code/hops}/$2\" || return; }"
}

create_path_alias  c          ~/code
create_hops_nav    h          hops
create_hops_nav    hm         hops-metadata-dal
create_hops_nav    hmi        hops-metadata-dal-impl-ndb
create_hops_nav    hmis       hops-metadata-dal-impl-ndb/schema
create_hops_nav    hs         hopsfs-standalone
create_path_alias  ei         ~/code/hops/ec2-init
create_hops_nav    hb         hammer-bench
create_path_alias  ds         ~/code/hops/HopsFS-Deployment-Scripts
create_path_alias  d          ~/code/dotfiles
create_path_alias  D          ~/Downloads
create_path_alias  r          ~/code/hops/rondb
create_path_alias  r2         ~/code/hops/rondb2
create_path_alias  rd         ~/code/hops/rondb-docker
create_path_alias  rest       ~/code/hops/rondb/storage/ndb/rest-server
create_path_alias  rest2      ~/code/hops/rondb/storage/ndb/rest-server2/server
create_hops_nav    hmnt       hopsfs-go/hopsfs-go-mount
create_hops_nav    libhdfs    hops/hadoop-hdfs-project/hadoop-hdfs/src/main/native/libhdfs-golang
